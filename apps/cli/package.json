{
  "name": "devstats-cli",
  "version": "0.1.1",
  "description": "Local telemetry for AI coding tools (Claude Code, Cursor, Codex, Windsurf, Antigravity) — parses your logs, uploads to devstats.me.",
  "keywords": [
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "windsurf",
    "antigravity",
    "ai",
    "telemetry",
    "developer-tools",
    "leaderboard"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "devstats": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup && chmod +x dist/index.js",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@devstats/parsers": "workspace:*",
    "@devstats/types": "workspace:*",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
